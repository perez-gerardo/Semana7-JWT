<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>JWT Auth — Administración</title>
  <link rel="stylesheet" href="/materialize/css/materialize.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<script src="/js/auth.js"></script>
<%- include('partials/navbar') %>

<div class="container">
  <div class="row">
    <div class="col s12">
      <h4>Panel de Control</h4>
      <p class="grey-text">Administración global de usuarios y permisos.</p>
    </div>
  </div>

  <div class="row">
    <div class="col s12 m4">
      <div class="card stat-card">
        <div class="stat-label">Total Usuarios</div>
        <div class="stat-val" id="total">—</div>
      </div>
    </div>
    <div class="col s12 m4">
      <div class="card stat-card">
        <div class="stat-label">Administradores</div>
        <div class="stat-val" id="admins" style="color: var(--success-color);">—</div>
      </div>
    </div>
    <div class="col s12 m4">
      <div class="card stat-card">
        <div class="stat-label">Usuarios Regulares</div>
        <div class="stat-val" id="regular">—</div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col s12">
      <div class="card">
        <div class="card-content">
          <span class="card-title" style="margin-bottom: 24px;">Listado Maestro</span>
          <div class="table-wrap">
            <table class="highlight">
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Email</th>
                  <th>Teléfono</th>
                  <th>Edad</th>
                  <th>Rol</th>
                  <th>Registro</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody id="tbody">
                <tr><td colspan="7" class="center grey-text" style="padding:40px !important;">Sincronizando base de datos...</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Modal -->
<div id="modal-detail" class="modal">
  <div class="modal-content" style="background-color: var(--card-bg); color: var(--text-primary);">
    <h5 id="m-name" style="font-weight: 800; margin-bottom: 24px;">—</h5>
    <div class="info-row"><span class="info-key">Email</span><span class="info-val" id="m-email">—</span></div>
    <div class="info-row"><span class="info-key">Teléfono</span><span class="info-val" id="m-phone">—</span></div>
    <div class="info-row"><span class="info-key">Fecha Nac.</span><span class="info-val" id="m-birth">—</span></div>
    <div class="info-row"><span class="info-key">Edad</span><span class="info-val" id="m-age">—</span></div>
    <div class="info-row"><span class="info-key">Roles</span><span class="info-val" id="m-roles">—</span></div>
    <div class="info-row"><span class="info-key">Registro</span><span class="info-val" id="m-created">—</span></div>
  </div>
  <div class="modal-footer" style="background-color: var(--card-bg); border-top: 1px solid var(--border-color);">
    <a href="#!" class="modal-close btn-flat" style="color: var(--text-primary); font-weight: 600;">Cerrar</a>
  </div>
</div>

<script src="/materialize/js/materialize.min.js"></script>
<script>
  requireRole('admin');
  let modalInst;

  document.addEventListener('DOMContentLoaded', function(){
    modalInst = M.Modal.init(document.getElementById('modal-detail'));
    load();
  });

  function showDetail(u) {
    document.getElementById('m-name').textContent   = (u.name||'') + ' ' + (u.lastName||'');
    document.getElementById('m-email').textContent  = u.email;
    document.getElementById('m-phone').textContent  = u.phoneNumber || '—';
    document.getElementById('m-birth').textContent  = u.birthdate ? fmtDate(u.birthdate) : '—';
    document.getElementById('m-age').textContent    = u.birthdate ? calcAge(u.birthdate) + ' años' : '—';
    const roles = (u.roles||[]).map(r => r.name || r).join(', ').toUpperCase();
    document.getElementById('m-roles').textContent  = roles;
    document.getElementById('m-created').textContent= fmtDate(u.createdAt);
    modalInst.open();
  }

  async function load() {
    const users = await apiGet('/users');
    if (!users) return;
    const adm = users.filter(u => (u.roles||[]).some(r => (r.name||r)==='admin'));
    document.getElementById('total').textContent  = users.length;
    document.getElementById('admins').textContent = adm.length;
    document.getElementById('regular').textContent= users.length - adm.length;

    document.getElementById('tbody').innerHTML = users.map((u, i) => {
      const roleNames = (u.roles||[]).map(r => r.name||r);
      const isAdmin = roleNames.includes('admin');
      const badge = `<span class="chip ${isAdmin?'admin-chip':'user-chip'}">${roleNames.join(', ').toUpperCase()}</span>`;
      return `<tr>
        <td>${(u.name||'—')} ${(u.lastName||'')}</td>
        <td>${u.email}</td>
        <td>${(u.phoneNumber||'—')}</td>
        <td>${(u.birthdate ? calcAge(u.birthdate) : '—')}</td>
        <td>${badge}</td>
        <td>${fmtDate(u.createdAt)}</td>
        <td><button class="btn-small waves-effect waves-dark" style="background-color: var(--accent-color); color: #000; font-weight: 700; border-radius: 4px;" onclick='showDetail(${JSON.stringify(u)})'>Ver</button></td>
      </tr>`;
    }).join('');
  }
</script>
</body>
</html>
