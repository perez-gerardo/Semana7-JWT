<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>JWT Auth — Dashboard</title>
  <link rel="stylesheet" href="/materialize/css/materialize.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<script src="/js/auth.js"></script>
<%- include('partials/navbar') %>

<div class="container">
  <div class="row">
    <div class="col s12">
      <h4>Bienvenido, <span id="user-name" style="color: var(--text-primary);">—</span></h4>
      <p class="grey-text">Resumen de tu cuenta y actividad reciente.</p>
    </div>
  </div>

  <div class="row">
    <div class="col s12 m4">
      <div class="card stat-card">
        <div class="stat-label">Rol actual</div>
        <div class="stat-val" id="s-rol">—</div>
      </div>
    </div>
    <div class="col s12 m4">
      <div class="card stat-card">
        <div class="stat-label">Edad</div>
        <div class="stat-val" id="s-age">—</div>
      </div>
    </div>
    <div class="col s12 m4">
      <div class="card stat-card">
        <div class="stat-label">Año de Ingreso</div>
        <div class="stat-val" id="s-since">—</div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col s12">
      <div class="card">
        <div class="card-content">
          <span class="card-title">Información del Perfil</span>
          <div class="info-row"><span class="info-key">Nombre Completo</span><span class="info-val" id="d-name">—</span></div>
          <div class="info-row"><span class="info-key">Email</span><span class="info-val" id="d-email">—</span></div>
          <div class="info-row"><span class="info-key">Teléfono</span><span class="info-val" id="d-phone">—</span></div>
          <div class="info-row"><span class="info-key">Fecha de Nacimiento</span><span class="info-val" id="d-birth">—</span></div>
          <div class="info-row"><span class="info-key">Dirección</span><span class="info-val" id="d-addr">—</span></div>
          <div style="margin-top: 32px;">
            <a href="/profile" class="btn waves-effect waves-dark" style="background-color: var(--accent-color); color: #000; font-weight: 700; border-radius: 6px;">Editar Perfil</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/materialize/js/materialize.min.js"></script>
<script>
  requireAuth();

  async function load() {
    const u = await apiGet('/users/me');
    if (!u) return;
    document.getElementById('user-name').textContent = u.name;
    document.getElementById('s-rol').textContent  = u.roles.join(', ').toUpperCase();
    document.getElementById('s-age').textContent  = u.birthdate ? calcAge(u.birthdate) : '—';
    document.getElementById('s-since').textContent= u.createdAt ? new Date(u.createdAt).getFullYear() : '—';
    document.getElementById('d-name').textContent = (u.name||'') + ' ' + (u.lastName||'');
    document.getElementById('d-email').textContent= u.email;
    document.getElementById('d-phone').textContent= u.phoneNumber || '—';
    document.getElementById('d-birth').textContent= u.birthdate ? fmtDate(u.birthdate) : '—';
    document.getElementById('d-addr').textContent = u.address || 'No especificada';
  }
  load();
</script>
</body>
</html>
