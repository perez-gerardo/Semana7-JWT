<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>JWT Auth — Mi Perfil</title>
  <link rel="stylesheet" href="/materialize/css/materialize.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<script src="/js/auth.js"></script>
<%- include('partials/navbar') %>

<div class="container">
  <div class="row">
    <div class="col s12">
      <h4>Configuración de Perfil</h4>
      <p class="grey-text">Actualiza tu información personal y preferencias.</p>
    </div>
  </div>

  <div class="row">
    <div class="col s12 m4">
      <div class="card center-align" style="padding: 40px 20px;">
        <div class="avatar-box" id="avatar" style="width: 100px; height: 100px; font-size: 2.5rem; background-color: var(--border-color); margin: 0 auto; display: flex; align-items: center; justify-content: center; border-radius: 50%;">?</div>
        <h5 id="p-name" style="font-weight: 800; margin-top: 24px;">—</h5>
        <p class="grey-text" id="p-email" style="font-size: 0.9rem; margin-bottom: 24px;">—</p>
        <div id="p-chips"></div>
        <div class="divider" style="background-color: var(--border-color); margin: 32px 0;"></div>
        <div class="info-row"><span class="info-key">Edad</span><span class="info-val" id="p-age">—</span></div>
        <div class="info-row"><span class="info-key">Miembro desde</span><span class="info-val" id="p-since">—</span></div>
      </div>
    </div>

    <div class="col s12 m8">
      <div class="card">
        <div class="card-content">
          <span class="card-title" style="margin-bottom: 32px;">Editar Información</span>
          <div id="alert" class="auth-alert hide"></div>
          <div id="ok"    class="auth-ok    hide"></div>
          <form id="form-profile">
            <div class="row mb0">
              <div class="input-field col s6">
                <input id="f-name" type="text" class="validate">
                <label for="f-name" class="active">Nombre</label>
              </div>
              <div class="input-field col s6">
                <input id="f-last" type="text" class="validate">
                <label for="f-last" class="active">Apellido</label>
              </div>
            </div>
            <div class="input-field">
              <input id="f-phone" type="tel" class="validate">
              <label for="f-phone" class="active">Teléfono</label>
            </div>
            <div class="row mb0">
              <div class="input-field col s6">
                <input id="f-birth" type="date" class="validate">
                <label for="f-birth" class="active">Fecha de Nacimiento</label>
              </div>
              <div class="input-field col s6">
                <input id="f-addr" type="text" class="validate">
                <label for="f-addr" class="active">Dirección</label>
              </div>
            </div>
            <div class="input-field">
              <input id="f-url" type="url" class="validate">
              <label for="f-url" class="active">URL de Perfil</label>
            </div>
            <div style="margin-top: 32px;">
              <button type="submit" class="btn waves-effect waves-dark" style="background-color: var(--accent-color); color: #000; font-weight: 700; border-radius: 6px; width: 100%;">Guardar Cambios</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="/materialize/js/materialize.min.js"></script>
<script>
  requireAuth();

  async function loadProfile() {
    const u = await apiGet('/users/me');
    if (!u) return;
    document.getElementById('avatar').textContent = ((u.name||'?')[0] + (u.lastName||'?')[0]).toUpperCase();
    document.getElementById('p-name').textContent = (u.name||'') + ' ' + (u.lastName||'');
    document.getElementById('p-email').textContent= u.email;
    document.getElementById('p-age').textContent  = u.birthdate ? calcAge(u.birthdate) + ' años' : '—';
    document.getElementById('p-since').textContent= fmtDate(u.createdAt);
    document.getElementById('p-chips').innerHTML  = (u.roles||[]).map(r => `<span class="chip user-chip">${r.toUpperCase()}</span>`).join(' ');
    document.getElementById('f-name').value  = u.name        || '';
    document.getElementById('f-last').value  = u.lastName    || '';
    document.getElementById('f-phone').value = u.phoneNumber || '';
    document.getElementById('f-birth').value = u.birthdate   ? u.birthdate.substring(0,10) : '';
    document.getElementById('f-addr').value  = u.address     || '';
    document.getElementById('f-url').value   = u.url_profile || '';
    M.updateTextFields();
  }

  document.getElementById('form-profile').addEventListener('submit', async function(e) {
    e.preventDefault();
    const res = await apiPut('/users/me', {
      name:        document.getElementById('f-name').value,
      lastName:    document.getElementById('f-last').value,
      phoneNumber: document.getElementById('f-phone').value,
      birthdate:   document.getElementById('f-birth').value,
      address:     document.getElementById('f-addr').value,
      url_profile: document.getElementById('f-url').value
    });
    const ok = document.getElementById('ok'), al = document.getElementById('alert');
    if (res && res.status === 200) {
      ok.textContent = 'Perfil actualizado con éxito.'; ok.classList.remove('hide'); al.classList.add('hide');
      loadProfile();
    } else {
      al.textContent = res?.data?.message || 'Error al guardar'; al.classList.remove('hide'); ok.classList.add('hide');
    }
  });

  document.addEventListener('DOMContentLoaded', function(){ M.AutoInit(); loadProfile(); });
</script>
</body>
</html>
