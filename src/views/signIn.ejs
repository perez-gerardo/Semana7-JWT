<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>JWT Auth — Iniciar Sesión</title>
  <link rel="stylesheet" href="/materialize/css/materialize.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
<div class="auth-wrap">
  <div class="auth-card card z-depth-0">
    <div class="card-content">
      <div class="auth-brand">JWT Auth<span class="dot">.</span></div>
      <h5 class="auth-title">Iniciar Sesión</h5>
      <p class="auth-sub">Ingresa a la plataforma de gestión</p>

      <div id="alert" class="auth-alert hide"></div>

      <form id="form-signin">
        <div class="input-field">
          <input id="email" type="email" required class="validate">
          <label for="email">Correo electrónico</label>
        </div>
        <div class="input-field">
          <input id="password" type="password" required class="validate">
          <label for="password">Contraseña</label>
        </div>
        <button id="btn" type="submit" class="btn btn-block waves-effect waves-dark">
          Ingresar
        </button>
      </form>
      <p class="auth-footer">¿Aún no tienes cuenta? <a href="/signUp">Regístrate ahora</a></p>
    </div>
  </div>
</div>
<script src="/materialize/js/materialize.min.js"></script>
<script src="/js/auth.js"></script>
<script>
  document.getElementById('form-signin').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('btn');
    btn.disabled = true; btn.textContent = 'Verificando...';

    const res = await apiPost('/auth/signIn', {
      email: document.getElementById('email').value,
      password: document.getElementById('password').value
    });

    if (res.status === 200) {
      setToken(res.data.token);
      const p = parseJwt(res.data.token);
      window.location.href = p.roles.includes('admin') ? '/admin/dashboard' : '/dashboard';
    } else {
      const a = document.getElementById('alert');
      a.textContent = res.data.message || 'Credenciales incorrectas';
      a.classList.remove('hide');
      btn.disabled = false; btn.textContent = 'Ingresar';
    }
  });
</script>
</body>
</html>
