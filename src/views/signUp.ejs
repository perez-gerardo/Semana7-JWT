<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>JWT Auth — Registro</title>
  <link rel="stylesheet" href="/materialize/css/materialize.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-body">
<div class="auth-wrap wide" style="max-width: 500px;">
  <div class="auth-card card z-depth-0">
    <div class="card-content">
      <div class="auth-brand">JWT Auth<span class="dot">.</span></div>
      <h5 class="auth-title">Crear cuenta</h5>
      <p class="auth-sub">Regístrate para acceder a las herramientas</p>

      <div id="alert" class="auth-alert hide"></div>
      <div id="ok"    class="auth-ok    hide"></div>

      <form id="form-signup">
        <div class="row mb0">
          <div class="input-field col s6">
            <input id="name" type="text" required class="validate">
            <label for="name">Nombre</label>
          </div>
          <div class="input-field col s6">
            <input id="lastName" type="text" required class="validate">
            <label for="lastName">Apellido</label>
          </div>
        </div>
        <div class="input-field">
          <input id="email" type="email" required class="validate">
          <label for="email">Correo electrónico</label>
        </div>
        <div class="row mb0">
          <div class="input-field col s6">
            <input id="phoneNumber" type="tel" required class="validate">
            <label for="phoneNumber">Teléfono</label>
          </div>
          <div class="input-field col s6">
            <input id="birthdate" type="date" required class="validate">
            <label for="birthdate" class="active">Fecha de nacimiento</label>
          </div>
        </div>
        <div class="input-field">
          <input id="password" type="password" required class="validate">
          <label for="password">Contraseña</label>
          <span class="helper-text">Mín. 8 caracteres (A, 1, #)</span>
        </div>
        <button id="btn" type="submit" class="btn btn-block waves-effect waves-dark">
          Registrarse
        </button>
      </form>
      <p class="auth-footer">¿Ya eres parte de Axis? <a href="/signIn">Inicia sesión</a></p>
    </div>
  </div>
</div>
<script src="/materialize/js/materialize.min.js"></script>
<script src="/js/auth.js"></script>
<script>
  document.getElementById('form-signup').addEventListener('submit', async function(e) {
    e.preventDefault();
    const btn = document.getElementById('btn');
    btn.disabled = true; btn.textContent = 'Procesando...';

    const res = await apiPost('/auth/signUp', {
      name:        document.getElementById('name').value,
      lastName:    document.getElementById('lastName').value,
      email:       document.getElementById('email').value,
      phoneNumber: document.getElementById('phoneNumber').value,
      birthdate:   document.getElementById('birthdate').value,
      password:    document.getElementById('password').value,
      roles:       ['user']
    });

    if (res.status === 201) {
      document.getElementById('ok').textContent = 'Registro exitoso. Redirigiendo...';
      document.getElementById('ok').classList.remove('hide');
      setTimeout(() => { window.location.href = '/signIn'; }, 1500);
    } else {
      const a = document.getElementById('alert');
      a.textContent = res.data.message || 'Error en el registro';
      a.classList.remove('hide');
      btn.disabled = false; btn.textContent = 'Registrarse';
    }
  });
</script>
</body>
</html>
